{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@trip-planner/shared": ["packages/shared/src/index.ts"],
      "@trip-planner/shared/*": ["packages/shared/src/*"]
    }
  }
}
